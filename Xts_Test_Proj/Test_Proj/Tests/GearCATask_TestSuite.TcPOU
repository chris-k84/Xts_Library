    </Method>
    <Method Name="TaskRejectGearwithNoMasterRefs_Test" Id="{3962e37a-30d9-468d-8447-b46584f032b9}">
      <Declaration><![CDATA[METHOD TaskRejectGearwithNoMasterRefs_Test
VAR
	testAxis : XtsMover;
	testGearTask : GearCATask := (slaveAxis := testAxis);
	Expected : BOOL := TRUE;
	Actual	 : BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF ThisTestSuite.Test(__POUNAME()).ExecuteTest() THEN
	Actual := FAILED(testGearTask.GearIn(MasterPosition := 0, SlavePosition := 0));
	ThisTestSuite.Test(__POUNAME()).AssertEqual(Expected, Actual);
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="TaskRejectsDuplicateGearIn_Test" Id="{e6e0c511-05f8-4a0a-8d53-1681a7fdf699}">
      <Declaration><![CDATA[METHOD TaskRejectsDuplicateGearIn_Test
VAR
	testMaster : XtsMover;
	testAxis : XtsMover;
	testGearTask : GearCATask := (slaveAxis := testAxis, MasterAxis := testMaster);
	Expected : BOOL := TRUE;
	Actual	 : BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF ThisTestSuite.Test(__POUNAME()).ExecuteTest() THEN
	testGearTask.GearIn(0,0);
	Actual := FAILED(testGearTask.GearIn(MasterPosition := 0, SlavePosition := 0));
	ThisTestSuite.Test(__POUNAME()).AssertEqual(Expected, Actual);
END_IF]]></ST>
      </Implementation>
    </Method>
