<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="GearCATask_TestSuite" Id="{061b6bca-7336-459c-b0e8-a83117c82ddd}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK GearCATask_TestSuite
VAR
	ThisTestSuite : TestSuite<TestSuiteParameter.MaxTestCount>('C:\ProgramData\Beckhoff\TwinCAT\3.1\Boot\GearTask_Tests.xml') := (TestSuiteName := 'GearTask Test Suite');
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[TaskAcceptsGearCommand_Test();
TaskAcceptsMasterAxisRef_Test();
TaskAcceptsSlaveAxisRef_Test();
TaskRejectCyclewithNoSlaveAxisRef_Test();
TaskRejectCyclewithNoMasterRefs_Test();
TaskRejectsGearWithNoSlaveAxisRef_Test();
TaskRejectGearwithNoMasterRefs_Test();
TaskRejectsDuplicateGearIn_Test();
TaskRejectsNullMasterAxis_Test();
TaskRejectsNullSlaveAxis_Test();
TaskCorrectlyClearsAxes_Test();
TaskRejectsMasterSameAsSlave_Test();
TaskRejectsSlaveSameAsMaster_Test();]]></ST>
    </Implementation>
    <Method Name="TaskAcceptsGearCommand_Test" Id="{acd9c547-0c6e-4db9-bf91-fa3e2f9bc389}">
      <Declaration><![CDATA[METHOD TaskAcceptsGearCommand_Test
VAR
	testMaster : XtsMover;
	testAxis : XtsMover;
	testGearTask : GearCATask := (slaveAxis := testAxis, MasterAxis := testMaster);
	Expected : BOOL := TRUE;
	Actual	 : BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF ThisTestSuite.Test(__POUNAME()).ExecuteTest() THEN
	Actual := SUCCEEDED(testGearTask.GearIn(1.0,1.0));
	testGearTask.Abort();
	ThisTestSuite.Test(__POUNAME()).AssertEqual(Expected, Actual);
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="TaskAcceptsMasterAxisRef_Test" Id="{3dbb10c8-a050-4f84-a313-4e8a48bc1f62}">
      <Declaration><![CDATA[METHOD TaskAcceptsMasterAxisRef_Test
VAR
	testMaster : XtsMover;
	iTestMaster : I_XtsMover := testMaster;
	testGearTask : GearCATask;
	Expected : BOOL := TRUE;
	Actual	 : BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF ThisTestSuite.Test(__POUNAME()).ExecuteTest() THEN
	testGearTask.MasterAxis := testMaster;
	Actual := testGearTask.MasterAxis = iTestMaster;
	ThisTestSuite.Test(__POUNAME()).AssertEqual(Expected, Actual);
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="TaskAcceptsSlaveAxisRef_Test" Id="{14457ff7-f154-4e41-97da-03af2af55014}">
      <Declaration><![CDATA[METHOD TaskAcceptsSlaveAxisRef_Test
VAR
	testSlave : XtsMover;
	iTestSlave : I_XtsMover := testSlave;
	testGearTask : GearCATask;
	Expected : BOOL := TRUE;
	Actual	 : BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF ThisTestSuite.Test(__POUNAME()).ExecuteTest() THEN
	testGearTask.SlaveAxis := testSlave;
	Actual := testGearTask.SlaveAxis = iTestSlave;
	ThisTestSuite.Test(__POUNAME()).AssertEqual(Expected, Actual);
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="TaskCorrectlyClearsAxes_Test" Id="{94ee14b4-bec0-4267-8161-7197588a842c}">
      <Declaration><![CDATA[METHOD TaskCorrectlyClearsAxes_Test
VAR
	testMaster : XtsMover;
	testAxis : XtsMover;
	testGearTask : GearCATask := (slaveAxis := testAxis, MasterAxis := testMaster);
	Expected : BOOL := TRUE;
	Actual	 : BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF ThisTestSuite.Test(__POUNAME()).ExecuteTest() THEN
	testGearTask.ClearAxes();
	Actual := (testGearTask.SlaveAxis = 0) AND (testGearTask.MasterAxis = 0);
	ThisTestSuite.Test(__POUNAME()).AssertEqual(Expected, Actual);
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="TaskRejectCyclewithNoMasterRefs_Test" Id="{dc5295ee-0a48-4be8-81f1-301f8ca559bd}">
      <Declaration><![CDATA[METHOD TaskRejectCyclewithNoMasterRefs_Test
VAR
	testAxis : XtsMover;
	testGearTask : GearCATask := (slaveAxis := testAxis);
	Expected : BOOL := TRUE;
	Actual	 : BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF ThisTestSuite.Test(__POUNAME()).ExecuteTest() THEN
	Actual := FAILED(testGearTask.Cycle());
	ThisTestSuite.Test(__POUNAME()).AssertEqual(Expected, Actual);
END_IF]]></ST>
      </Implementation>
    </Method>
