    <Method Name="TaskRejectsSlaveSameAsMaster_Test" Id="{e89b6cb1-bd72-4a2c-8070-36d5c3b2ebe1}">
      <Declaration><![CDATA[METHOD TaskRejectsSlaveSameAsMaster_Test
