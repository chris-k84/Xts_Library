	ThisTestSuite.Test(__POUNAME()).AssertEqual(Expected, Actual);
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="SequenceRejectsDuplicateCommand_Test" Id="{8dc243ec-fddf-46dc-ad15-142d6952e617}">
      <Declaration><![CDATA[METHOD SequenceRejectsDuplicateCommand_Test : BOOL
VAR
	stubCAGroup : CollisionGroup;
	DisableSequence : XtsDisableSequence := (MyCollisionGroup := stubCAGroup);
	Expected : BOOL := TRUE;
	Actual	 : BOOL;
END_VAR

]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF ThisTestSuite.Test(__POUNAME()).ExecuteTest() THEN
	DisableSequence.Disable();
	Actual := FAILED(DisableSequence.Disable());
	ThisTestSuite.Test(__POUNAME()).AssertEqual(Expected, Actual);
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="SequenceRejectsNullMoverRegister_Test" Id="{68970958-d2f6-4e5b-b69b-d3ab6e330d4c}">
      <Declaration><![CDATA[METHOD SequenceRejectsNullMoverRegister_Test
VAR
	stub_Mover : I_XtsMover;
	DisableSequence : XtsDisableSequence;
