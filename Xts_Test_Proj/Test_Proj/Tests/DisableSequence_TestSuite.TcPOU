<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="DisableSequence_TestSuite" Id="{f559856d-01d4-4848-9917-85e528e26102}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK DisableSequence_TestSuite
VAR
	ThisTestSuite : TestSuite<TestSuiteParameter.MaxTestCount>('C:\ProgramData\Beckhoff\TwinCAT\3.1\Boot\DisableSeq_Tests.xml') := (TestSuiteName := 'DisableSequence Test Suite');
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[SequenceAcceptsDisableCommand_Test();
SequenceRejectsCommandWithNoAxes_Test();
SequenceRejectsCommandWithNoCAGroup_Test();
SequenceRejectsDuplicateCommand_Test();
SequenceAcceptsMover_Test();
SequenceRejectsNullMoverRegister_Test();
SequenceReportsCorrectMoverNumber_Test();]]></ST>
    </Implementation>
    <Method Name="SequenceAcceptsDisableCommand_Test" Id="{9968cbcb-1e07-4776-8222-2487796f2d34}">
      <Declaration><![CDATA[METHOD SequenceAcceptsDisableCommand_Test : BOOL
VAR
	stubCAGroup : CollisionGroup;
	stub_Mover : XtsMover;
	DisableSequence : XtsDisableSequence := (MyCollisionGroup := stubCAGroup);
	Expected : BOOL := TRUE;
	Actual	 : BOOL;
END_VAR

]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF ThisTestSuite.Test(__POUNAME()).ExecuteTest() THEN
	Actual := SUCCEEDED(DisableSequence.RegisterMovers(stub_Mover));
	ThisTestSuite.Test(__POUNAME()).AssertEqual(Expected, Actual);
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="SequenceAcceptsMover_Test" Id="{b4618248-f0d0-4c5f-875c-2296c561c8f6}">
      <Declaration><![CDATA[METHOD SequenceAcceptsMover_Test : BOOL
VAR
	stubCAGroup : CollisionGroup;
	stub_Mover : XtsMover;
	DisableSequence : XtsDisableSequence := (MyCollisionGroup := stubCAGroup);
	Expected : BOOL := TRUE;
	Actual	 : BOOL;
END_VAR

]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF ThisTestSuite.Test(__POUNAME()).ExecuteTest() THEN
	DisableSequence.RegisterMovers(stub_Mover);
	Actual := SUCCEEDED(DisableSequence.Disable());
	ThisTestSuite.Test(__POUNAME()).AssertEqual(Expected, Actual);
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="SequenceRejectsCommandWithNoAxes_Test" Id="{23a2eea3-b5fb-4474-bc7a-20d66dc6a2ed}">
      <Declaration><![CDATA[METHOD SequenceRejectsCommandWithNoAxes_Test : BOOL
VAR
	stubCAGroup : CollisionGroup;
	DisableSequence : XtsDisableSequence := (MyCollisionGroup := stubCAGroup);
	Expected : BOOL := TRUE;
	Actual	 : BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF ThisTestSuite.Test(__POUNAME()).ExecuteTest() THEN
	Actual := FAILED(DisableSequence.Disable());
	ThisTestSuite.Test(__POUNAME()).AssertEqual(Expected, Actual);
END_IF]]></ST>
      </Implementation>
    </Method>
