	Actual	 : BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF ThisTestSuite.Test(__POUNAME()).ExecuteTest() THEN
	Actual := FAILED(DisableSequence.RegisterMovers(stub_Mover));
	ThisTestSuite.Test(__POUNAME()).AssertEqual(Expected, Actual);
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="SequenceReportsCorrectMoverNumber_Test" Id="{038270fa-a665-4122-9a47-fc495276d17e}">
      <Declaration><![CDATA[METHOD SequenceReportsCorrectMoverNumber_Test : BOOL
VAR
	stubCAGroup : CollisionGroup;
	stub_Mover1 : stubMover;
	stub_Mover2 : stubMover;
	stub_Mover3 : stubMover;
	DisableSequence : XtsDisableSequence := (MyCollisionGroup := stubCAGroup);
	Expected : BOOL := TRUE;
	Actual	 : BOOL;
END_VAR

]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF ThisTestSuite.Test(__POUNAME()).ExecuteTest() THEN
	DisableSequence.RegisterMovers(stub_Mover1);
	DisableSequence.RegisterMovers(stub_Mover2);
	DisableSequence.RegisterMovers(stub_Mover3);
	Actual := DisableSequence.RegisteredMoverNumber = 3;
	ThisTestSuite.Test(__POUNAME()).AssertEqual(Expected, Actual);
END_IF]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>