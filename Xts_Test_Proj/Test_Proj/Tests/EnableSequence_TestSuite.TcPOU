<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="EnableSequence_TestSuite" Id="{0a7c423d-1ec1-40a1-84cd-1f7627cf2709}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK EnableSequence_TestSuite
VAR
	ThisTestSuite : TestSuite<TestSuiteParameter.MaxTestCount>('C:\ProgramData\Beckhoff\TwinCAT\3.1\Boot\EnableSequence_Tests.xml') := (TestSuiteName := 'EnableSequence Test Suite');
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[SequenceAcceptsEnableCommand_Test();
SequenceRejectsCommandWithNoAxes_Test();
SequenceRejectsCommandWithNoCAGroup_Test();
SequenceRejectsDuplicateCommand_Test();
SequenceAcceptsMover_Test();
SequenceRejectsNullMoverRegister_Test();
SequenceReportsCorrectMoverNumber_Test();]]></ST>
    </Implementation>
    <Method Name="SequenceAcceptsEnableCommand_Test" Id="{d8f7a973-bbd5-4c8b-b462-c79ceb666984}">
      <Declaration><![CDATA[METHOD SequenceAcceptsEnableCommand_Test : BOOL
VAR
	stubCAGroup : CollisionGroup;
	stubMover : XtsMover;
	EnableSequence : XtsEnableSequence := (MyCollisionGroup := stubCAGroup);
	Expected : BOOL := TRUE;
	Actual	 : BOOL;
END_VAR

]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF ThisTestSuite.Test(__POUNAME()).ExecuteTest() THEN
	EnableSequence.RegisterMovers(stubMover);
	Actual := SUCCEEDED(EnableSequence.Enable());
	ThisTestSuite.Test(__POUNAME()).AssertEqual(Expected, Actual);
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="SequenceAcceptsMover_Test" Id="{e91a3164-80ca-4533-820c-a6b0c8f9e00c}">
      <Declaration><![CDATA[METHOD SequenceAcceptsMover_Test : BOOL
VAR
	stubCAGroup : CollisionGroup;
	stub_Mover : XtsMover;
