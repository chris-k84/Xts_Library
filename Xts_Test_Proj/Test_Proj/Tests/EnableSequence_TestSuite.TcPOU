	ThisTestSuite.Test(__POUNAME()).AssertEqual(Expected, Actual);
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="SequenceReportsCorrectMoverNumber_Test" Id="{98aae470-b0db-41b9-8128-0a32e5302399}">
      <Declaration><![CDATA[METHOD SequenceReportsCorrectMoverNumber_Test : BOOL
VAR
	stubCAGroup : CollisionGroup;
	stub_Mover1 : stubMover;
	stub_Mover2 : stubMover;
	stub_Mover3 : stubMover;
	EnableSequence : XtsEnableSequence := (MyCollisionGroup := stubCAGroup);
	Expected : BOOL := TRUE;
	Actual	 : BOOL;
END_VAR

]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF ThisTestSuite.Test(__POUNAME()).ExecuteTest() THEN
	EnableSequence.RegisterMovers(stub_Mover1);
	EnableSequence.RegisterMovers(stub_Mover2);
	EnableSequence.RegisterMovers(stub_Mover3);
	Actual := EnableSequence.RegisteredMoverNumber = 3;
	ThisTestSuite.Test(__POUNAME()).AssertEqual(Expected, Actual);
END_IF]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>