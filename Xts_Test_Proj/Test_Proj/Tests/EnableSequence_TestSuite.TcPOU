END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="SequenceRejectsNullMoverRegister_Test" Id="{8a9fa3df-ea12-4bf8-957f-b81e6275d244}">
      <Declaration><![CDATA[METHOD SequenceRejectsNullMoverRegister_Test
VAR
